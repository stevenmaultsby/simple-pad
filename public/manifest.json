{
    "manifest_version": 3,
    "name": "commented",
    "version": "0.1",
    "icons": {
        "32": "icons/icon32.png"
    },
    "permissions": ["activeTab", "scripting"],
    "host_permissions": ["https://*/*", "http://*/*"],
    "browser_specific_settings": {
        "gecko": {
            "id": "{a0b0439c-fba3-43ec-bfcb-f7415fd998a3}",
            "data_collection_permissions":{
              "required":["browsingActivity", "websiteContent"]
            }
        }
    },
    "action": {
        "default_icon": "icons/icon64.png",
        "default_title": "commented",
        "default_popup": "index.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_end"
        }
    ],
    "background": {
        "scripts": ["scripts/background.js"],
        "type": "module"
    },

    "web_accessible_resources": [
        {
            "resources": [
                "webpage_addon/js/main.js",
                "webpage_addon/css/main.css"
            ],
            "matches": ["*://*/*"]
        }
    ]
}
